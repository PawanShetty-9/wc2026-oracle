# betting/.streamlit/secrets.toml.example
# =========================================
# Copy this file to secrets.toml and fill in your API keys.
# NEVER commit secrets.toml to git — it is in .gitignore.
#
# Without any keys, the app runs in DEMO MODE (fully functional,
# uses bundled World Cup 2026 data and hardcoded odds).

# ── Football data.org (live match results) ────────────────────────────────────
# Free tier: 10 calls/minute, all World Cup 2026 data included
# Sign up at: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY = ""

# ── The Odds API (live bookmaker odds) ────────────────────────────────────────
# Free tier: 500 requests/month (our 30-min cache makes this last 6+ months)
# Sign up at: https://the-odds-api.com/#get-access
ODDS_API_KEY = ""
